# SignWell API key — get from https://www.signwell.com → Settings → API
SIGNWELL_API_KEY=your_api_key_here

# Default mode for CLI commands. Override per-call with --test / --prod.
# "test" = SignWell test_mode=true (free, unlimited, NOT legally binding)
# "prod" = real documents, counts against quota, legally binding
INVOICER_DEFAULT_MODE=test

# Path to clients registry (optional, defaults to ./clients.yaml)
# INVOICER_CLIENTS_PATH=./clients.yaml

# Path to local tracking DB (optional, defaults to ./sent.sqlite)
# INVOICER_DB_PATH=./sent.sqlite

# Sender info shown in the signature request email
INVOICER_SENDER_NAME="Andrew Last"
INVOICER_SENDER_EMAIL="andrew@example.com"
